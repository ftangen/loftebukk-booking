# Kopier denne filen til .env og tilpass verdiene

# Port serveren kjører på (standard: 3000)
PORT=3000

# URL til siden (brukes i e-postlenker)
SITE_URL=https://booking.10w-30mc.no

# Admin-brukere: navn:passord,navn2:passord2
# (ADMIN_PASSWORD brukes som fallback om ADMINS ikke er satt)
ADMINS=Fredrik:passord1,Kari:passord2

# Hemmelighet for session-kryptering (bytt til en tilfeldig streng i produksjon)
SESSION_SECRET=bytt-meg-til-noe-tilfeldig-og-langt

# ── E-postvarsler (Google Workspace) ──────────────────
# Lag et App-passord på: myaccount.google.com → Sikkerhet → App-passord
# (Krever at 2-trinnsverifisering er aktivert på kontoen)
SMTP_USER=din@adresse.no
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# E-post admin skal motta varsler på
ADMIN_EMAIL=admin@adresse.no
